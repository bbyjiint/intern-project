{
  "name": "intern-website-backend",
  "private": true,
  "type": "module",
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "scripts": {
    "dev": "tsx watch src/utils/server.ts",
    "build": "tsc",
    "start": "node dist/utils/server.js",
    "prisma:studio": "npx prisma studio --config=./prisma.config.ts",
    "prisma:generate": "npx prisma generate --config=./prisma.config.ts",
    "prisma:migrate": "npx prisma migrate dev --config=./prisma.config.ts",
    "prisma:dbpull": "npx prisma db pull --config=./prisma.config.ts",
    "prisma:validate": "npx prisma validate --config=./prisma.config.ts",
    "seed:addresses-direct": "tsx prisma/seed-addresses-direct.ts",
    "seed:users": "tsx prisma/seed-users.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@types/multer": "^2.0.0",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "google-auth-library": "^10.4.1",
    "jose": "^6.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "pg": "^8.16.3",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.9",
    "@types/pg": "^8.15.5",
    "prisma": "^7.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
